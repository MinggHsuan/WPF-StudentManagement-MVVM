<Window x:Class="StudentManagementMVVM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudentManagementMVVM"
        mc:Ignorable="d"
        Title="學生管理系統"
        Height="600"
        Width="1000"
        Background="#F3EFE7">


    <Window.Resources>


        <local:VisibleConverter x:Key="converter"/>


        <!-- 日式柔和陰影 -->
        <DropShadowEffect x:Key="Shadow"
                          BlurRadius="12"
                          ShadowDepth="3"
                          Opacity="0.18"/>



        <!-- Label -->

        <Style TargetType="Label">

            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#3C3836"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

        </Style>



        <!-- TextBox -->

        <Style TargetType="TextBox">


            <Setter Property="Width" Value="130"/>

            <Setter Property="Height" Value="38"/>

            <Setter Property="FontSize" Value="15"/>

            <Setter Property="Padding" Value="10"/>

            <Setter Property="Margin" Value="5"/>


            <Setter Property="Background"
                    Value="#FFFDF8"/>


            <Setter Property="BorderBrush"
                    Value="#CFC5B5"/>


            <Setter Property="BorderThickness"
                    Value="1"/>


        </Style>




        <!-- Button -->

        <Style TargetType="Button">


            <Setter Property="Width" Value="100"/>

            <Setter Property="Height" Value="38"/>

            <Setter Property="Margin" Value="8"/>


            <Setter Property="Background"
                    Value="#78866B"/>


            <Setter Property="Foreground"
                    Value="White"/>


            <Setter Property="FontSize"
                    Value="15"/>



            <Setter Property="Template">


                <Setter.Value>

                    <ControlTemplate TargetType="Button">


                        <Border

                            Background="{TemplateBinding Background}"

                            CornerRadius="6">


                            <ContentPresenter

                                HorizontalAlignment="Center"

                                VerticalAlignment="Center"/>


                        </Border>


                    </ControlTemplate>


                </Setter.Value>


            </Setter>




            <Style.Triggers>


                <Trigger Property="IsMouseOver"
                         Value="True">


                    <Setter Property="Background"
                            Value="#647052"/>


                </Trigger>



                <Trigger Property="IsPressed"
                         Value="True">


                    <Setter Property="Opacity"
                            Value="0.6"/>


                </Trigger>



            </Style.Triggers>


        </Style>






        <!-- 清單 Label -->

        <Style x:Key="ItemLabelStyle"
               TargetType="Label">


            <Setter Property="Width"
                    Value="100"/>


            <Setter Property="Margin"
                    Value="10"/>


            <Setter Property="Visibility"
                    Value="{Binding IsClick,
                    Converter={StaticResource converter},
                    ConverterParameter=Forward}"/>


        </Style>





        <Style x:Key="ItemTextBoxStyle"
               TargetType="TextBox">


            <Setter Property="Width"
                    Value="100"/>


            <Setter Property="Visibility"
                    Value="{Binding IsClick,
                    Converter={StaticResource converter},
                    ConverterParameter=Reverse}"/>


        </Style>


    </Window.Resources>




    <Grid Margin="35">


        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition/>

        </Grid.RowDefinitions>






        <!-- 新增學生 -->

        <Border

            Background="#FFFDF8"

            Padding="25"

            CornerRadius="12"

            Effect="{StaticResource Shadow}">


            <StackPanel>



                <TextBlock

                    Text="學生管理系統"

                    FontSize="26"

                    FontWeight="SemiBold"

                    Foreground="#4A4036"

                    Margin="0 0 0 20"/>





                <StackPanel Orientation="Horizontal">


                    <Label Content="班級"/>

                    <TextBox Text="{Binding InputClass}"/>



                    <Label Content="座號"/>

                    <TextBox Text="{Binding InputNumber}"/>



                    <Label Content="姓名"/>

                    <TextBox Text="{Binding InputName}"/>



                    <Label Content="成績"/>

                    <TextBox Text="{Binding InputScore}"/>



                    <Button Content="新增"
                            Command="{Binding Button_Click}"/>



                </StackPanel>



            </StackPanel>


        </Border>








        <ScrollViewer Grid.Row="1"
                      Margin="0 25 0 0">


            <ItemsControl ItemsSource="{Binding StudentList}">



                <ItemsControl.ItemTemplate>



                    <DataTemplate>


                        <Border

                            Background="#FFFDF8"

                            Margin="0 6"

                            Padding="12"

                            CornerRadius="10"

                            Effect="{StaticResource Shadow}">



                            <StackPanel Orientation="Horizontal">


                                <Label Content="{Binding Class}"
                                       Style="{StaticResource ItemLabelStyle}"/>


                                <TextBox Text="{Binding Class}"
                                         Style="{StaticResource ItemTextBoxStyle}"/>



                                <Label Content="{Binding Number}"
                                       Style="{StaticResource ItemLabelStyle}"/>



                                <TextBox Text="{Binding Number}"
                                         Style="{StaticResource ItemTextBoxStyle}"/>




                                <Label Content="{Binding Name}"
                                       Style="{StaticResource ItemLabelStyle}"/>


                                <TextBox Text="{Binding Name}"
                                         Style="{StaticResource ItemTextBoxStyle}"/>




                                <Label Content="{Binding Score}"
                                       Style="{StaticResource ItemLabelStyle}"/>


                                <TextBox Text="{Binding Score}"
                                         Style="{StaticResource ItemTextBoxStyle}"/>




                                <Button Content="刪除"

                                Background="#B56B6B"

                                Command="{Binding DataContext.RemoveData,
                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"

                                CommandParameter="{Binding}"/>





                                <Button Content="{Binding EditContent}"

                                Command="{Binding DataContext.EditData,
                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"

                                CommandParameter="{Binding}"/>



                            </StackPanel>



                        </Border>



                    </DataTemplate>



                </ItemsControl.ItemTemplate>


            </ItemsControl>



        </ScrollViewer>



    </Grid>


</Window>