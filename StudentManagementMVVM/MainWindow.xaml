<Window x:Class="StudentManagementMVVM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudentManagementMVVM"
        mc:Ignorable="d"
        Title="學生管理系統" Height="450" Width="900">
    <Window.Resources>
        <local:VisibleConverter x:Key="converter">
        </local:VisibleConverter>
    </Window.Resources>
    <StackPanel x:Name="Stackpanel" Orientation="Vertical">
        <StackPanel.Resources>
            <Style x:Key="LabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="30"></Setter>
            </Style>
            <Style x:Key="TextBoxStyle" TargetType="TextBox">
                <Setter Property="Width" Value="100"></Setter>
                <Setter Property="FontSize" Value="30"></Setter>
            </Style>
            <Style x:Key="ItemLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="20"></Setter>
                <Setter Property="Margin" Value="0,0,10,0"></Setter>
                <Setter Property="Visibility" Value="{Binding IsClick, Converter={StaticResource converter},ConverterParameter=Forward}"></Setter>
            </Style>
            <Style x:Key="ItemTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxStyle}">
                <Setter Property="Margin" Value="0,0,10,0"></Setter>
                <Setter Property="Visibility" Value="{Binding IsClick, Converter={StaticResource converter},ConverterParameter=Reverse}"></Setter>
            </Style>
        </StackPanel.Resources>

        <StackPanel x:Name="panel" Orientation="Horizontal">
            <Label Content="班級:" Style="{StaticResource LabelStyle}"></Label>
            <TextBox Text="{Binding InputClass}" Style="{StaticResource TextBoxStyle}"></TextBox>
            <Label Content="座號:" Style="{StaticResource LabelStyle}"></Label>
            <TextBox Text="{Binding InputNumber}" Style="{StaticResource TextBoxStyle}"></TextBox>
            <Label Content="學生姓名:" Style="{StaticResource LabelStyle}"></Label>
            <TextBox Text="{Binding InputName}" Style="{StaticResource TextBoxStyle}"></TextBox>
            <Label Content="成績:" Style="{StaticResource LabelStyle}" ></Label>
            <TextBox Text="{Binding InputScore}" Style="{StaticResource TextBoxStyle}" Margin="0,0,20,0"></TextBox>
            <Button Content="送出" Width="100"  Command="{Binding Button_Click}" ></Button>
        </StackPanel>

        <ItemsControl ItemsSource="{Binding StudentList}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="{Binding Class}" Style="{StaticResource ItemLabelStyle}"></Label>
                        <TextBox Text="{Binding Class}"  Style="{StaticResource ItemTextBoxStyle}"></TextBox>
                        <Label Content="{Binding Number}"  Style="{StaticResource ItemLabelStyle}"></Label>
                        <TextBox Text="{Binding Number}" Style="{StaticResource ItemTextBoxStyle}"></TextBox>
                        <Label Content="{Binding Name}"  Style="{StaticResource ItemLabelStyle}"></Label>
                        <TextBox Text="{Binding Name}"  Style="{StaticResource ItemTextBoxStyle}"></TextBox>
                        <Label Content="{Binding Score}" Style="{StaticResource ItemLabelStyle}"></Label>
                        <TextBox Text="{Binding Score}"  Style="{StaticResource ItemTextBoxStyle}"></TextBox>
                        <Button Content="刪除" Width="100" Command="{Binding DataContext.RemoveData, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"></Button>
                        <Button Content="{Binding EditContent}" Width="100" Command="{Binding DataContext.EditData,RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"></Button>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</Window>