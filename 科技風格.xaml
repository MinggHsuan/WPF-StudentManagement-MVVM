<Window x:Class="StudentManagementMVVM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudentManagementMVVM"
        mc:Ignorable="d"
        Title="學生管理系統"
        Height="600" Width="1000"
        Background="#0D1117"
        FontFamily="Microsoft JhengHei UI">

    <Window.Resources>
        <local:VisibleConverter x:Key="converter"/>

        <!-- 色彩定義 -->
        <SolidColorBrush x:Key="BgPrimary"     Color="#0D1117"/>
        <SolidColorBrush x:Key="BgSurface"     Color="#161B22"/>
        <SolidColorBrush x:Key="BgCard"        Color="#1C2333"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#58A6FF"/>
        <SolidColorBrush x:Key="AccentCyan"    Color="#39D353"/>
        <SolidColorBrush x:Key="BorderColor"   Color="#30363D"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#7D8590"/>
        <SolidColorBrush x:Key="DangerColor"   Color="#F85149"/>
        <SolidColorBrush x:Key="DangerHover"   Color="#DA3633"/>

        <!-- Label 樣式 -->
        <Style x:Key="FieldLabel" TargetType="Label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Padding" Value="0,0,0,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 輸入框樣式 -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                <Setter TargetName="border" Property="Background" Value="#161B22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主送出按鈕 -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0D1117"/>
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#79B8FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#388BFD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 刪除按鈕 -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource DangerColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="62"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2D1B1B"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource DangerHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3D2020"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 編輯按鈕 -->
        <Style x:Key="EditButton" TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="62"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A2A3A"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#79B8FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1F3050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 列表項 Label（可見時） -->
        <Style x:Key="ItemLabelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Visibility" Value="{Binding IsClick, Converter={StaticResource converter}, ConverterParameter=Forward}"/>
        </Style>

        <!-- 列表項 TextBox（編輯時） -->
        <Style x:Key="ItemTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputBox}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Visibility" Value="{Binding IsClick, Converter={StaticResource converter}, ConverterParameter=Reverse}"/>
        </Style>

        <!-- 列表項 Class Label（有自己的 Visibility，不走 Style） -->
        <Style x:Key="ClassLabelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="90"/>
        </Style>

        <!-- 列表項 Class TextBox（有自己的 Visibility） -->
        <Style x:Key="ClassTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputBox}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Width" Value="90"/>
        </Style>

    </Window.Resources>

    <!-- 最外層捲動容器 -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Background="{StaticResource BgPrimary}">

        <StackPanel Margin="24,20,24,32">

            <!-- ── 標題列 ── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Rectangle Width="4" Height="24" Fill="{StaticResource AccentBlue}"
                           RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                <TextBlock Text="學生管理系統"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"
                           Margin="12,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Text="Student Management"
                           FontSize="13"
                           Foreground="{StaticResource TextMuted}"
                           Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- ── 輸入區塊 ── -->
            <Border Background="{StaticResource BgSurface}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0" Content="班級" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Column="1" Text="{Binding InputClass}"
                             Style="{StaticResource InputBox}"/>

                    <Label Grid.Column="3" Content="座號" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Column="4" Text="{Binding InputNumber}"
                             Style="{StaticResource InputBox}"/>

                    <Label Grid.Column="6" Content="學生姓名" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Column="7" Text="{Binding InputName}"
                             Style="{StaticResource InputBox}"/>

                    <Label Grid.Column="9" Content="成績" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Column="10" Text="{Binding InputScore}"
                             Style="{StaticResource InputBox}"/>

                    <Button Grid.Column="12"
                            Content="＋ 新增"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding Button_Click}"/>
                </Grid>
            </Border>

            <!-- ── 列表標頭 ── -->
            <Border Margin="0,20,0,0"
                    Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1,1,1,0"
                    CornerRadius="8,8,0,0"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="班級"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="座號"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="姓名"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="成績"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="操作"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ── 資料列表 ── -->
            <Border BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,8,8"
                    ClipToBounds="True">
                <ItemsControl ItemsSource="{Binding StudentList}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="rowBorder"
                                    Background="{StaticResource BgSurface}"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="0,0,0,1"
                                    Padding="16,10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1C2333"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 班級 -->
                                    <Label Grid.Column="0"
                                           Content="{Binding Class}"
                                           Style="{StaticResource ClassLabelStyle}"
                                           Visibility="{Binding IsClick, Converter={StaticResource converter}, ConverterParameter=Forward}"/>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Class}"
                                             Style="{StaticResource ClassTextBoxStyle}"
                                             Visibility="{Binding IsClick, Converter={StaticResource converter}, ConverterParameter=Reverse}"/>

                                    <!-- 座號 -->
                                    <Label Grid.Column="1"
                                           Content="{Binding Number}"
                                           Style="{StaticResource ItemLabelStyle}"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Number}"
                                             Style="{StaticResource ItemTextBoxStyle}"
                                             Width="80" HorizontalAlignment="Left"/>

                                    <!-- 姓名 -->
                                    <Label Grid.Column="2"
                                           Content="{Binding Name}"
                                           Style="{StaticResource ItemLabelStyle}"/>
                                    <TextBox Grid.Column="2"
                                             Text="{Binding Name}"
                                             Style="{StaticResource ItemTextBoxStyle}"
                                             Width="120" HorizontalAlignment="Left"/>

                                    <!-- 成績 -->
                                    <Label Grid.Column="3"
                                           Content="{Binding Score}"
                                           Style="{StaticResource ItemLabelStyle}"/>
                                    <TextBox Grid.Column="3"
                                             Text="{Binding Score}"
                                             Style="{StaticResource ItemTextBoxStyle}"
                                             Width="80" HorizontalAlignment="Left"/>

                                    <!-- 操作按鈕 -->
                                    <StackPanel Grid.Column="4"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Spacing="8">
                                        <Button Content="刪除"
                                                Style="{StaticResource DangerButton}"
                                                Command="{Binding DataContext.RemoveData, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="{Binding EditContent}"
                                                Style="{StaticResource EditButton}"
                                                Command="{Binding DataContext.EditData, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- ── 底部說明 ── -->
            <TextBlock Text="點擊「編輯」可直接修改欄位，完成後再次點擊儲存。"
                       FontSize="12"
                       Foreground="{StaticResource TextMuted}"
                       Margin="4,12,0,0"/>

        </StackPanel>
    </ScrollViewer>
</Window>
